# Hermes Agent — Environment Configuration
# Copy to data/.env and fill in your keys.
# If migrating from OpenClaw, the migrate.sh script copies these automatically.

# ── LLM Provider ────────────────────────────────────────────────────────────
# OpenRouter (same key as OpenClaw)
# OPENROUTER_API_KEY=sk-or-v1-...

# AWS Bedrock (uses standard AWS credentials)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# ── Messaging ───────────────────────────────────────────────────────────────
# Telegram (same token as OpenClaw — but a bot can only connect to ONE agent)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_USERS=

# ── Tool Keys ───────────────────────────────────────────────────────────────
# Google API (for skills like nano-banana-pro)
# GOOGLE_API_KEY=
